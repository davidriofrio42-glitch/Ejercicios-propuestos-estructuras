#include <iostream>
using namespace std;

int main() {
    int cartas[6];
    int cantidad = 6;

    cout << "--- MAZO DE CARTAS MAGICAS ---" << endl;
    // Pedimos al usuario que ingrese los valores
    for(int i = 0; i < cantidad; i++) {
        cout << "Ingresa el nivel de ataque de la carta " << i + 1 << ": ";
        cin >> cartas[i];
    }

    // Método de Ordenamiento por Inserción
    for(int i = 1; i < cantidad; i++) {
        int cartaActual = cartas[i];
        int j = i - 1;

        // Desplazamos las cartas mayores hacia la derecha para hacer espacio
        while(j >= 0 && cartas[j] > cartaActual) {
            cartas[j + 1] = cartas[j];
            j--;
        }
        // Insertamos la carta en el espacio vacío que creamos
        cartas[j + 1] = cartaActual;
    }

    // Mostrar los resultados
    cout << "\nMazo ordenado (De menor a mayor ataque):" << endl;
    for(int i = 0; i < cantidad; i++) {
        cout << "[" << cartas[i] << "] ";
    }
    
    cout << "\n\nAnalisis del mazo:" << endl;
    cout << "Carta mas debil: " << cartas[0] << endl;
    cout << "CARTA JEFE (Mas fuerte): " << cartas[cantidad - 1] << endl;

    return 0;
}
