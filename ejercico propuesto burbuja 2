#include <iostream>
#include <string>
using namespace std;

// Estructura para almacenar los datos de cada canción
struct Cancion {
    string titulo;
    int reproducciones;
    int duracionSegundos;
};

int main() {
    // Arreglo de canciones (desordenadas)
    Cancion playlist[] = {
        {"Bohemian Rhapsody", 500, 354},
        {"Shape of You", 800, 233},
        {"Blinding Lights", 800, 200}, // Mismas reproducciones, pero más corta
        {"Hotel California", 300, 390},
        {"Despacito", 950, 228}
    };
    int cantidad = 5;

    cout << "--- ORDENANDO TU PLAYLIST ---" << endl;

    // Método Burbuja con Doble Condición
    for (int i = 0; i < cantidad - 1; i++) {
        for (int j = 0; j < cantidad - i - 1; j++) {
            
            // Regla 1: Ordenar por mayor número de reproducciones
            // Regla 2: Si hay empate, ordenar por menor duración
            bool intercambiar = false;

            if (playlist[j].reproducciones < playlist[j + 1].reproducciones) {
                intercambiar = true;
            } else if (playlist[j].reproducciones == playlist[j + 1].reproducciones) {
                if (playlist[j].duracionSegundos > playlist[j + 1].duracionSegundos) {
                    intercambiar = true;
                }
            }

            // Si se cumple alguna condición, hacemos el Swap (intercambio)
            if (intercambiar) {
                Cancion temporal = playlist[j];
                playlist[j] = playlist[j + 1];
                playlist[j + 1] = temporal;
            }
        }
    }

    // Mostrar el resultado
    cout << "\nPlaylist final (Mas escuchadas y cortas primero):" << endl;
    for (int i = 0; i < cantidad; i++) {
        cout << i + 1 << ". " << playlist[i].titulo 
             << " | Reprods: " << playlist[i].reproducciones 
             << " | Duracion: " << playlist[i].duracionSegundos << "s" << endl;
    }

    return 0;
}
