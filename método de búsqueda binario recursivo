#include <iostream>
using namespace std;

// Función Recursiva
int verificarHistorialMedico(int archivos[], int limiteInferior, int limiteSuperior, int numHistoria, int paso) {
    // Rastro para consola
    cout << "Paso " << paso << " | Revisando gavetas desde " << limiteInferior << " hasta " << limiteSuperior << endl;

    // Caso base: se agotaron las opciones
    if (limiteInferior > limiteSuperior) {
        return -1;
    }

    // Calculamos la mitad
    int carpetaCentral = limiteInferior + (limiteSuperior - limiteInferior) / 2;
    cout << "  -> Extrayendo carpeta central: " << archivos[carpetaCentral] << endl;

    // Si coincide el número de historia
    if (archivos[carpetaCentral] == numHistoria) {
        return carpetaCentral;
    }

    // Recursividad: Si el número buscado es mayor, buscar en la mitad superior
    if (archivos[carpetaCentral] < numHistoria) {
        cout << "  -> El paciente " << numHistoria << " debe estar en las gavetas de arriba.\n";
        return verificarHistorialMedico(archivos, carpetaCentral + 1, limiteSuperior, numHistoria, paso + 1);
    } 
    // Recursividad: Si es menor, buscar en la mitad inferior
    else {
        cout << "  -> El paciente " << numHistoria << " debe estar en las gavetas de abajo.\n";
        return verificarHistorialMedico(archivos, limiteInferior, carpetaCentral - 1, numHistoria, paso + 1);
    }
}

int main() {
    // Números de Historia Clínica (Deben estar estrictamente ordenados)
    int historiasClinicas[] = {3045, 4102, 5500, 6890, 7021, 8834, 9105, 9999};
    int cantidadArchivos = 8;
    int pacienteActual;

    cout << "--- RECEPCION DEL HOSPITAL ---" << endl;
    cout << "Ingrese el numero de Historia Clinica del paciente: ";
    cin >> pacienteActual;

    cout << "\nIniciando busqueda en el archivo fisico...\n";
    int resultado = verificarHistorialMedico(historiasClinicas, 0, cantidadArchivos - 1, pacienteActual, 1);

    // Impresión de resultados
    if (resultado != -1) {
        cout << "\n[RESULTADO] Paciente Encontrado." << endl;
        cout << "El expediente medico esta ubicado en la gaveta numero: " << resultado << endl;
    } else {
        cout << "\n[RESULTADO] Paciente NO Encontrado." << endl;
        cout << "Por favor, proceda a abrir un nuevo expediente medico en el sistema." << endl;
    }

    return 0;
}
