#include <iostream>
using namespace std;

// Función de búsqueda binaria con bucle WHILE
int busquedaBinariaIterativa(int catalogo[], int totalLibros, int isbnBuscado) {
    int inicio = 0;
    int fin = totalLibros - 1;

    // Mientras el rango de búsqueda sea válido
    while (inicio <= fin) {
        int medio = inicio + (fin - inicio) / 2;
        
        cout << " -> Buscando entre indices [" << inicio << " y " << fin << "]. Centro: " << medio << endl;

        // Caso 1: Lo encontramos en el centro
        if (catalogo[medio] == isbnBuscado) {
            return medio;
        }
        // Caso 2: El objetivo es mayor, descartamos la mitad izquierda
        if (catalogo[medio] < isbnBuscado) {
            inicio = medio + 1;
        } 
        // Caso 3: El objetivo es menor, descartamos la mitad derecha
        else {
            fin = medio - 1;
        }
    }
    return -1; // No se encontró
}

int main() {
    // Los códigos ISBN ya deben estar ordenados
    int librosISBN[] = {1001, 2045, 3300, 4890, 5012, 6789, 8890, 9901};
    int total = 8;
    int buscar;
    char continuar;

    cout << "--- SISTEMA DE BIBLIOTECA ---" << endl;

    do {
        cout << "\nIngrese el codigo ISBN del libro a buscar: ";
        cin >> buscar;

        int resultado = busquedaBinariaIterativa(librosISBN, total, buscar);

        if (resultado != -1) {
            cout << "[EXITO] Libro encontrado en el estante (indice) " << resultado << endl;
        } else {
            cout << "[ERROR] El libro no existe en el catalogo." << endl;
        }

        cout << "¿Desea buscar otro libro? (s/n): ";
        cin >> continuar;

    } while (continuar == 's' || continuar == 'S');

    cout << "Cerrando sistema..." << endl;
    return 0;
}
