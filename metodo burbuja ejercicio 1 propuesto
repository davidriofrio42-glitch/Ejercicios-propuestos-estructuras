#include <iostream>
using namespace std;

int main() {
    // Arreglo con los puntajes desordenados del día
    int puntajes[] = {4500, 10200, 3200, 8900, 7500};
    int cantidad = 5;

    cout << "--- LEADERBOARD DEL ARCADE ---" << endl;
    cout << "Ordenando puntajes de mayor a menor...\n" << endl;

    // Método de Burbuja Descendente
    for (int i = 0; i < cantidad - 1; i++) {
        for (int j = 0; j < cantidad - i - 1; j++) {
            // Evaluamos si el actual es MENOR que el siguiente
            if (puntajes[j] < puntajes[j + 1]) {
                // Si es menor, hacemos el intercambio (swap) para que el mayor suba
                int temporal = puntajes[j];
                puntajes[j] = puntajes[j + 1];
                puntajes[j + 1] = temporal;
            }
        }
    }

    // Imprimir el resultado final
    cout << "Ranking Final:" << endl;
    for (int i = 0; i < cantidad; i++) {
        cout << i + 1 << " LUGAR: " << puntajes[i] << " pts";
        // Condición para el récord
        if (i == 0 && puntajes[i] > 10000) {
            cout << " -> !NUEVO RECORD!";
        }
        cout << endl;
    }

    return 0;
}
